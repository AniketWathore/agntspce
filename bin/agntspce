#!/usr/bin/env bash
# agntspce - Token-aware command wrapper
# Rewrites commands via the Rust rtk binary or the built-in Node.js filter.
# Bare invocations (e.g. "agntspce git status") are treated as "run" calls.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

case "${1:-}" in
  rewrite)
    shift
    node "$SCRIPT_DIR/agntspce.mjs" rewrite "$@"
    ;;
  run)
    shift
    exec node "$SCRIPT_DIR/agntspce.mjs" run "$@"
    ;;
  *)
    # Bare commands like "agntspce git status" — treat as "run git status".
    # This is the format produced by the Rust RTK binary's rewrite engine.
    exec node "$SCRIPT_DIR/agntspce.mjs" run "$@"
    ;;
esac
